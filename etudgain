    // autres restaurants ...
  ],
};

const categories = Object.keys(OFFRES);

// Logo composant
function Logo() {
  return (
    <View style={styles.logoContainer}>
      <Text style={styles.logoText}>Etudgain</Text>
    </View>
  );
}

// Écran d'accueil
function HomeScreen({ navigation }) {
  return (
    <View style={styles.container}>
      <StatusBar barStyle="light-content" />
      <Logo />
      <Text style={styles.title}>Bienvenue sur Etudgain !</Text>
      <Text style={styles.subtitle}>Choisissez une catégorie :</Text>

      {categories.map((cat) => (
        <TouchableOpacity
          key={cat}
          style={styles.homeButton}
          onPress={() => navigation.navigate('Category', { category: cat })}
        >
          <Text style={styles.homeButtonText}>{cat}</Text>
        </TouchableOpacity>
      ))}
    </View>
  );
}

// Écran liste des offres par catégorie
function CategoryScreen({ route, navigation }) {
  const { category } = route.params;
  const [searchText, setSearchText] = useState('');

  const data = OFFRES[category] || [];

  // Recherche dans titres ou noms (title ou name)
  const filteredData = data.filter(item =>
    ((item.title || item.name) ?? '').toLowerCase().includes(searchText.toLowerCase())
  );

  return (
    <View style={styles.container}>
      <StatusBar barStyle="light-content" />
      <Logo />
      <Text style={styles.title}>{category}</Text>

      <TextInput
        style={styles.searchInput}
        placeholder={`Rechercher dans ${category}...`}
        placeholderTextColor="#999"
        value={searchText}
        onChangeText={setSearchText}
      />

      <FlatList
        data={filteredData}
        keyExtractor={item => item.id}
        renderItem={({ item }) => (
          <TouchableOpacity
            style={styles.card}
            onPress={() => navigation.navigate('Detail', { item })}
          >
            <Image source={{ uri: item.image }} style={styles.cardImage} />
            <View style={styles.cardContent}>
              <Text style={styles.cardTitle}>{item.title || item.name}</Text>
              {item.price && <Text style={styles.cardPrice}>{item.price}</Text>}
            </View>
          </TouchableOpacity>
        )}
        contentContainerStyle={{ paddingBottom: 20 }}
      />
    </View>
  );
}

// Écran détail d’une offre
function DetailScreen({ route }) {
  const { item } = route.params;

  return (
    <View style={styles.container}>
      <StatusBar barStyle="light-content" />
      <Logo />
      <Text style={styles.detailTitle}>{item.title || item.name}</Text>
      <Image source={{ uri: item.image }} style={styles.detailImage} />
      <View style={styles.detailInfo}>
        {item.price && <Text style={styles.detailText}><Text style={{ fontWeight: 'bold' }}>Prix: </Text>{item.price}</Text>}
        {item.address ? (
          <Text style={styles.detailText}><Text style={{ fontWeight: 'bold' }}>Adresse: </Text>{item.address}</Text>
        ) : null}
        {item.description ? (
          <Text style={styles.detailText}><Text style={{ fontWeight: 'bold' }}>Description: </Text>{item.description}</Text>
        ) : null}
      </View>
    </View>
  );
}

export default function App() {
  return (
    <NavigationContainer>
      <Stack.Navigator
        initialRouteName="Home"
        screenOptions={{
          headerStyle: { backgroundColor: '#f39c12' },
          headerTintColor: '#2c3e50',
          headerTitleStyle: { fontWeight: 'bold' },
        }}
      >
        <Stack.Screen
          name="Home"
          component={HomeScreen}
          options={{ title: 'Accueil' }}
        />
        <Stack.Screen
          name="Category"
          component={CategoryScreen}
          options={({ route }) => ({ title: route.params.category })}
        />
        <Stack.Screen
          name="Detail"
          component={DetailScreen}
          options={({ route }) => ({ title: route.params.item.title || route.params.item.name })}
        />
      </Stack.Navigator>
    </NavigationContainer>
  );
}

